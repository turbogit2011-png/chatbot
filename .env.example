# =============================================================================
# Turbo-Git Forge — PRZYKŁADOWE zmienne środowiskowe (BEZ WARTOŚCI)
# =============================================================================
# ZASADY:
#  - Ten plik jest jawny i NIE zawiera sekretów. To tylko lista wymaganych zmiennych.
#  - Prawdziwe wartości ustawiasz WYŁĄCZNIE w panelu hostingu (Vercel/Cloudflare/Render)
#    jako Environment Variables. NIGDY nie commituj pliku .env z wartościami.
#  - Frontend (apps/storefront) NIGDY nie widzi WC_SECRET — używa go tylko backend (apps/api).
# =============================================================================

# --- apps/api (backend-for-frontend) — SERVER-SIDE ONLY ---
# Read-only klucz WooCommerce REST (uprawnienia: Read). Ustaw w hostingu, nie tutaj.
WC_STORE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# Bezpieczeństwo BFF
API_RATE_LIMIT_RPM=60           # limit zapytań na minutę na IP
API_ALLOWED_ORIGINS=            # np. https://turbo-git.com (CORS allowlist)
API_LOG_LEVEL=info

# --- apps/storefront (Next.js) — PUBLIC (tylko nie-wrażliwe) ---
# Adres backendu BFF (publiczny). Bez żadnych kluczy WooCommerce.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SITE_URL=

# --- opcjonalne integracje (ustawiane server-side gdy potrzebne) ---
# GOOGLE_MERCHANT_ACCOUNT_ID=
# ALLEGRO_CLIENT_ID=
# ALLEGRO_CLIENT_SECRET=
